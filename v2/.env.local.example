# Tidy Tails v2 — local environment template.
# Copy to `.env.local` (gitignored) and fill in the values below.

# Live Supabase project — REQUIRED.
# As of Ship 2.2a the app uses real Supabase Auth, so these are needed on every
# request — not just for the optional live-data path. Project ref
# pgkwovokciaqnbhpttba. The anon key is the public client key; it is safe in the
# browser with RLS on. It is NOT the service_role key — never put service_role
# here. Do not commit a filled-in .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://pgkwovokciaqnbhpttba.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Data source. Leave unset (or anything other than "on") for anonymized
# fixtures. Set to "on" to read from the live Supabase project — SELECT only.
NEXT_PUBLIC_USE_LIVE_DATA=
