# Tidy Tails v2 — local environment template.
# Copy to `.env.local` (gitignored) and fill in the values below.

# Live Supabase project — REQUIRED.
# As of Ship 2.2a the app uses real Supabase Auth, so these are needed on every
# request — not just for the optional live-data path. Project ref
# pgkwovokciaqnbhpttba. The anon key is the public client key; it is safe in the
# browser with RLS on. It is NOT the service_role key — never put service_role
# here. Do not commit a filled-in .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://pgkwovokciaqnbhpttba.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Data source. Leave unset (or anything other than "on") for anonymized
# fixtures. Set to "on" to read from the live Supabase project — SELECT only.
NEXT_PUBLIC_USE_LIVE_DATA=

# Post-cutover write kill-switches — server-only, OFF by default.
# Each of v2's four write surfaces is gated by a PRIVATE flag. These are NOT
# prefixed NEXT_PUBLIC_ on purpose: the value must never reach the browser
# bundle. A surface persists data only when its flag is the EXACT string "on" —
# unset, empty, "false", "off", "true", "ON", or anything else keeps it OFF.
# Leave ALL of these unset until the Ship 2.2b RLS cutover is green AND the
# surface's flip is explicitly approved — see
# ../_reports/2026-05-18-ship-2.2b-write-flip-plan.md. Enabling or disabling a
# surface is a Vercel env change + redeploy, never a code edit.
TIDYTAILS_ENABLE_ADD_APPOINTMENT_WRITE=
TIDYTAILS_ENABLE_LOG_GROOM_WRITE=
TIDYTAILS_ENABLE_REMINDER_SEND=
TIDYTAILS_ENABLE_ADD_HOUSEHOLD_WRITE=
